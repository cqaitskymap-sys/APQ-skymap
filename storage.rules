rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function profileExists() {
      return firestore.exists(/databases/(default)/documents/profiles/$(request.auth.uid));
    }

    function getProfileRole() {
      return profileExists()
        ? firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.role
        : '';
    }

    function isSuperAdmin() {
      return isAuthenticated() && getProfileRole() == 'super_admin';
    }

    function isAdmin() {
      return isAuthenticated() && getProfileRole() in ['super_admin', 'admin'];
    }

    function isReadOnly() {
      return isAuthenticated() && getProfileRole() in ['auditor', 'viewer'];
    }

    function isAllowedMime() {
      return request.resource.contentType.matches('application/pdf')
        || request.resource.contentType.matches('application/vnd.*')
        || request.resource.contentType.matches('application/msword')
        || request.resource.contentType.matches('image/.*')
        || request.resource.contentType.matches('text/html')
        || request.resource.contentType.matches('text/csv');
    }

    function canWriteModuleFile() {
      return isAuthenticated()
        && !isReadOnly()
        && isAllowedMime()
        && request.resource.size < 25 * 1024 * 1024;
    }

    // Company site logos — authenticated users only; no profile role lookup (avoids rule failures)
    match /company-sites/{siteId}/{fileName} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin() || isSuperAdmin();
    }

    // Path: /moduleName/documentId/.../fileName (supports nested folders e.g. attachments/)
    match /{moduleName}/{documentId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if canWriteModuleFile();
      allow delete: if isAdmin() || isSuperAdmin();
    }

    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
