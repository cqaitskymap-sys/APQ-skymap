{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:fresh": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3001",
    "build": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next build",
    "generate:loaders": "node scripts/generate-route-loaders.mjs",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "emulators": "npx firebase emulators:start --only auth,firestore,storage",
    "deploy:storage": "firebase deploy --only storage",
    "configure:storage-cors": "node scripts/configure-storage-cors.mjs",
    "setup:admin": "node scripts/setup-default-admin.mjs"
  },
  "dependencies": {
