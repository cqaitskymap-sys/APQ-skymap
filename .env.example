# Copy to .env.local for local dev, or add these in Vercel → Settings → Environment Variables

# Firebase (required — from Firebase Console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Default admin email (must match Firebase Auth user — run: npm run setup:admin)
NEXT_PUBLIC_BOOTSTRAP_ADMIN_EMAIL=admin@apq-skymap.com

# Promote first Firebase Console login to Super Admin (set false after team setup)
NEXT_PUBLIC_BOOTSTRAP_FIRST_ADMIN=true

# Optional: Firestore long-polling when Chrome reports ERR_QUIC_PROTOCOL_ERROR / QUIC_TOO_MANY_RTOS
# or Network tab shows firestore.googleapis.com/Listen ... 400 (Bad Request).
# Long-polling is enabled automatically in local development; set true to force it in production:
# NEXT_PUBLIC_FIREBASE_FORCE_LONG_POLLING=true

# Effective Date Management cron (POST /api/dms/effective-date/activate)
# EFFECTIVE_DATE_CRON_SECRET=
# EFFECTIVE_DATE_API_URL=https://your-app.vercel.app/api/dms/effective-date/activate

# Periodic Review Management cron (POST /api/dms/periodic-review/schedule)
# PERIODIC_REVIEW_CRON_SECRET=
# PERIODIC_REVIEW_API_URL=https://your-app.vercel.app/api/dms/periodic-review/schedule

# Document Training Linkage cron (POST /api/dms/training-linkage/schedule)
# TRAINING_LINKAGE_CRON_SECRET=
# TRAINING_LINKAGE_API_URL=https://your-app.vercel.app/api/dms/training-linkage/schedule

# Change Impact Assessment cron (POST /api/dms/change-impact/schedule)
# CHANGE_IMPACT_CRON_SECRET=
# CHANGE_IMPACT_API_URL=https://your-app.vercel.app/api/dms/change-impact/schedule
# ARCHIVE_CRON_SECRET=
# ARCHIVE_API_URL=https://your-app.vercel.app/api/dms/archive/schedule
# RETENTION_CRON_SECRET=
# RETENTION_API_URL=https://your-app.vercel.app/api/dms/retention/schedule
# EXTERNAL_DOC_CRON_SECRET=
# EXTERNAL_DOC_API_URL=https://your-app.vercel.app/api/dms/external/schedule
# PRINT_CONTROL_CRON_SECRET=
# PRINT_CONTROL_API_URL=https://your-app.vercel.app/api/dms/print-control/schedule
# WATERMARK_CRON_SECRET=
# WATERMARK_API_URL=https://your-app.vercel.app/api/dms/watermarks/schedule
# DOCUMENT_AUDIT_CRON_SECRET=
# DOCUMENT_AUDIT_API_URL=https://your-app.vercel.app/api/dms/audit-trail/schedule

# LMS Integration (optional — for OAuth callbacks and credential encryption)
# LMS_ENCRYPTION_KEY=
# LMS_OAUTH_CLIENT_SECRET=
# LMS_WEBHOOK_SIGNING_SECRET=
