rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isActiveUser() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_active == true
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.access_status != 'pending';
    }

    function getProfileRole() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getProfileRole() == 'super_admin';
    }

    function isAdmin() {
      return isAuthenticated() && getProfileRole() in ['super_admin', 'admin'];
    }

    function isReadOnly() {
      return isAuthenticated() && getProfileRole() in ['auditor', 'viewer'];
    }

    function isNotReadOnly() {
      return isAuthenticated() && !isReadOnly();
    }

    function isQaRole() {
      return getProfileRole() in [
        'super_admin', 'admin', 'head_qa', 'qa_manager', 'qa_executive', 'qa'
      ];
    }

    function isQcRole() {
      return getProfileRole() in ['super_admin', 'admin', 'qc_manager', 'qc_executive', 'qc'];
    }

    function isProductionRole() {
      return getProfileRole() in ['super_admin', 'admin', 'production_manager', 'production_executive', 'production'];
    }

    function isEngineeringRole() {
      return getProfileRole() in ['super_admin', 'admin', 'engineering_manager', 'engineering_executive', 'engineering'];
    }

    function isWarehouseRole() {
      return getProfileRole() in ['super_admin', 'admin', 'warehouse_manager', 'warehouse_executive', 'warehouse'];
    }

    function isRegulatoryRole() {
      return getProfileRole() in ['super_admin', 'admin', 'regulatory_affairs', 'regulatory'];
    }

    function isTrainingCoordinator() {
      return getProfileRole() in [
        'super_admin', 'admin', 'head_qa', 'qa_manager', 'qa_executive', 'training_coordinator'
      ];
    }

    function isAuditCollection(name) {
      return name.matches('.*audit_trail.*')
        || name.matches('.*audit_logs.*')
        || name in ['cpv_audit_trail', 'audit_logs', 'audit_trail', 'packaging_audit_trail', 'audit_logs_material', 'integration_logs'];
    }

    function isRegisteredCollection(name) {
      return name.matches('cpv_.*')
        || name in [
          'users', 'roles', 'permissions', 'user_permissions', 'products', 'batches',
          'cpv_reviews', 'cpp_parameters', 'cpp_results',
          'cqa_parameters', 'cqa_results', 'risk_assessment',
          'pqr_records', 'pqr_documents', 'pqr_batches',
          'deviations', 'oos_records', 'oos', 'capa_records', 'capa',
          'change_controls', 'change_control', 'change_implementation_plans', 'change_implementation_tasks', 'change_implementation_actions',
          'change_risk_assessments',
          'change_impact_assessments',
          'stability_studies', 'stability',
          'complaints', 'recalls', 'recall_records', 'recall_reports', 'recall_distribution',
          'recall_recovery', 'recall_regulatory_notifications', 'recall_closure', 'recall_trends',
          'recall_approvals', 'recall_attachments', 'customers',
          'documents', 'dms_documents',
          'document_revisions', 'document_versions', 'document_approvals',
          'document_distribution', 'distribution_lists', 'distribution_groups',
          'document_acknowledgements', 'read_confirmations',
          'document_attachments', 'document_lifecycle',
          'document_reviews', 'review_workflows', 'review_steps', 'review_comments', 'review_checklists',
          'approval_delegations', 'approval_escalations', 'approval_comments', 'electronic_signatures',
          'signature_meanings', 'signature_sessions', 'signature_settings',
          'document_effective_dates', 'document_archives', 'document_archive',
          'archive_jobs', 'archive_policies', 'archive_requests', 'archive_restoration_requests', 'archive_locations', 'retention_policies',
          'retention_schedules', 'retention_reviews', 'retention_events', 'disposal_requests', 'disposal_approvals', 'disposal_certificates', 'legal_holds', 'regulatory_holds',
          'external_documents', 'external_document_versions', 'external_document_reviews', 'external_document_distribution', 'external_document_sources', 'external_document_categories',
          'supplier_documents', 'regulatory_documents', 'standards_documents', 'safety_documents', 'linked_internal_documents',
          'print_requests', 'printed_documents', 'print_copies', 'print_locations', 'print_distribution', 'print_reconciliation', 'print_returns', 'print_destruction',
          'watermark_templates', 'watermark_rules', 'watermark_history', 'document_watermarks',
          'audit_events', 'audit_exports', 'audit_filters',
          'periodic_reviews', 'review_schedules', 'review_decisions',
          'document_obsolete',
          'sop_master', 'sop_versions', 'sop_reviews', 'sop_approvals',
          'sop_training_links', 'sop_distribution', 'sop_acknowledgements',
          'sop_periodic_reviews', 'sop_archive',
          'work_instructions', 'wi_versions', 'wi_reviews', 'wi_approvals',
          'wi_training_links', 'wi_distribution', 'wi_acknowledgements',
          'wi_periodic_reviews', 'wi_archive',
          'forms_templates', 'form_versions', 'form_reviews', 'form_approvals',
          'form_distribution', 'form_acknowledgements', 'form_periodic_reviews',
          'form_archive', 'production_lines',
          'training_records', 'training_master', 'training_assignments', 'training_assessments',
          'training_effectiveness', 'training_matrix', 'training_matrix_compliance', 'training_attendance', 'competency_records',
          'document_training_links', 'sop_management', 'training_assignments_sessions',
          'training_certificates',
          'training_events', 'training_schedule', 'training_rooms', 'trainers', 'retraining_records',
          'trainer_certifications', 'trainer_assessment_checklists', 'induction_records',
          'training_needs_identification', 'job_descriptions', 'ojt_training_plans',
          'ojt_competency_matrix', 'self_reading_declarations', 'annual_training_plans',
          'training_requests', 'question_bank', 'questionnaires', 'questionnaire_attempts',
          'practical_assessments', 'training_settings', 'need_based_training',
          'external_training_records', 'trainer_qualifications', 'trainer_renewals',
          'training_automation_log', 'training_planner_items',
          'approval_workflows', 'approval_requests', 'approval_steps', 'approval_requests_history',
          'lms_connections', 'lms_courses', 'lms_users', 'lms_training_records',
          'lms_sync_jobs', 'integration_logs', 'integration_settings',
          'audits', 'audit_mgmt_records',
          'vendors', 'vendor_master', 'vendor_records',
          'validation_records', 'csv_systems',
          'equipment_master', 'equipment_records', 'calibration_records',
          'monitoring_records', 'warehouse_materials', 'warehouse_records',
          'ebmr_records', 'notifications',
          'material_master', 'packaging_material_master',
          'departments', 'designations', 'company_sites', 'parameters',
          'workflows', 'approval_matrix', 'document_numbering',
          'notification_settings', 'esign_settings', 'system_settings', 'backup_history'
        ];
    }

    function canWriteCollection(name) {
      return isSuperAdmin()
        || (isAdmin() && name in ['users', 'roles', 'permissions', 'products', 'batches', 'departments', 'designations'])
        || (isQaRole() && name in ['pqr_records', 'pqr_documents', 'deviations', 'capa_records', 'capa', 'change_controls', 'change_control', 'change_implementation_plans', 'change_implementation_tasks', 'change_implementation_actions', 'change_risk_assessments', 'change_impact_assessments', 'complaints', 'recalls', 'recall_records', 'recall_reports', 'recall_distribution', 'recall_recovery', 'recall_regulatory_notifications', 'recall_closure', 'recall_trends', 'recall_approvals', 'recall_attachments', 'stability_studies', 'training_records', 'training_master', 'training_assignments', 'training_assessments', 'training_effectiveness', 'training_matrix', 'training_matrix_compliance', 'training_attendance', 'competency_records', 'document_training_links', 'training_certificates', 'approval_workflows', 'approval_requests', 'approval_steps', 'approval_requests_history', 'approval_delegations', 'approval_escalations', 'approval_comments', 'electronic_signatures', 'signature_meanings', 'signature_sessions', 'signature_settings', 'documents', 'dms_documents', 'document_revisions', 'document_versions', 'document_approvals', 'document_distribution', 'distribution_lists', 'distribution_groups', 'document_acknowledgements', 'read_confirmations', 'document_attachments', 'document_lifecycle', 'document_reviews', 'review_workflows', 'review_steps', 'review_comments', 'review_checklists', 'document_effective_dates', 'periodic_reviews', 'review_schedules', 'review_decisions', 'document_archives', 'document_archive', 'archive_jobs', 'archive_policies', 'archive_requests', 'archive_restoration_requests', 'archive_locations', 'retention_policies', 'retention_schedules', 'retention_reviews', 'retention_events', 'disposal_requests', 'disposal_approvals', 'disposal_certificates', 'legal_holds', 'regulatory_holds', 'external_documents', 'external_document_versions', 'external_document_reviews', 'external_document_distribution', 'external_document_sources', 'external_document_categories', 'supplier_documents', 'regulatory_documents', 'standards_documents', 'safety_documents', 'linked_internal_documents', 'print_requests', 'printed_documents', 'print_copies', 'print_locations', 'print_distribution', 'print_reconciliation', 'print_returns', 'print_destruction', 'watermark_templates', 'watermark_rules', 'watermark_history', 'document_watermarks', 'audit_events', 'audit_exports', 'audit_filters', 'document_obsolete', 'sop_master', 'sop_versions', 'sop_reviews', 'sop_approvals', 'sop_training_links', 'sop_distribution', 'sop_acknowledgements', 'sop_periodic_reviews', 'sop_archive', 'sop_management', 'work_instructions', 'wi_versions', 'wi_reviews', 'wi_approvals', 'wi_training_links', 'wi_distribution', 'wi_acknowledgements', 'wi_periodic_reviews', 'wi_archive', 'forms_templates', 'form_versions', 'form_reviews', 'form_approvals', 'form_distribution', 'form_acknowledgements', 'form_periodic_reviews', 'form_archive', 'production_lines'])
        || (isTrainingCoordinator() && name in ['lms_connections', 'lms_courses', 'lms_users', 'lms_training_records', 'lms_sync_jobs', 'integration_logs', 'integration_settings', 'training_records', 'training_master', 'training_assignments', 'training_assessments', 'training_effectiveness', 'training_matrix', 'training_matrix_compliance', 'training_attendance', 'competency_records', 'training_certificates', 'training_events', 'training_schedule', 'training_rooms', 'trainers', 'retraining_records', 'training_assignments_sessions', 'approval_workflows', 'approval_requests', 'approval_steps', 'approval_requests_history', 'trainer_certifications', 'trainer_assessment_checklists', 'induction_records', 'training_needs_identification', 'job_descriptions', 'ojt_training_plans', 'ojt_competency_matrix', 'self_reading_declarations', 'annual_training_plans', 'training_requests', 'question_bank', 'questionnaires', 'questionnaire_attempts', 'practical_assessments', 'training_settings', 'need_based_training', 'external_training_records', 'trainer_qualifications', 'trainer_renewals', 'training_automation_log', 'training_planner_items'])
        || (isAdmin() && name in ['lms_connections', 'lms_courses', 'lms_users', 'lms_training_records', 'lms_sync_jobs', 'integration_logs', 'integration_settings', 'training_certificates', 'training_events', 'training_schedule', 'training_rooms', 'trainers', 'retraining_records', 'approval_workflows', 'approval_requests', 'approval_steps', 'approval_requests_history'])
        || (isQcRole() && name in ['oos_records', 'oos', 'cqa_parameters', 'cqa_results', 'stability_studies', 'stability'])
        || (isProductionRole() && name in ['batches', 'cpp_parameters', 'cpp_results', 'ebmr_records'])
        || (isEngineeringRole() && name in ['equipment_master', 'equipment_records', 'calibration_records', 'validation_records', 'csv_systems', 'monitoring_records'])
        || (isWarehouseRole() && name in ['warehouse_materials', 'warehouse_records', 'material_master', 'recall_distribution', 'recall_recovery'])
        || (isRegulatoryRole() && name in ['change_controls', 'change_control', 'recalls', 'recall_records', 'recall_regulatory_notifications', 'documents', 'dms_documents', 'document_revisions', 'document_versions', 'document_approvals', 'document_distribution', 'distribution_lists', 'distribution_groups', 'document_acknowledgements', 'read_confirmations', 'document_attachments', 'document_lifecycle', 'document_reviews', 'review_workflows', 'review_steps', 'review_comments', 'review_checklists', 'approval_delegations', 'approval_escalations', 'approval_comments', 'electronic_signatures', 'document_effective_dates', 'periodic_reviews', 'review_schedules', 'review_decisions', 'document_archives', 'document_archive', 'archive_jobs', 'archive_policies', 'archive_requests', 'archive_restoration_requests', 'archive_locations', 'retention_policies', 'retention_schedules', 'retention_reviews', 'retention_events', 'disposal_requests', 'disposal_approvals', 'disposal_certificates', 'legal_holds', 'regulatory_holds', 'external_documents', 'external_document_versions', 'external_document_reviews', 'external_document_distribution', 'external_document_sources', 'external_document_categories', 'supplier_documents', 'regulatory_documents', 'standards_documents', 'safety_documents', 'linked_internal_documents', 'print_requests', 'printed_documents', 'print_copies', 'print_locations', 'print_distribution', 'print_reconciliation', 'print_returns', 'print_destruction', 'watermark_templates', 'watermark_rules', 'watermark_history', 'document_watermarks', 'audit_events', 'audit_exports', 'audit_filters', 'document_obsolete', 'sop_master', 'sop_versions', 'sop_reviews', 'sop_approvals', 'sop_training_links', 'sop_distribution', 'sop_acknowledgements', 'sop_periodic_reviews', 'sop_archive', 'sop_management', 'work_instructions', 'wi_versions', 'wi_reviews', 'wi_approvals', 'wi_training_links', 'wi_distribution', 'wi_acknowledgements', 'wi_periodic_reviews', 'wi_archive', 'forms_templates', 'form_versions', 'form_reviews', 'form_approvals', 'form_distribution', 'form_acknowledgements', 'form_periodic_reviews', 'form_archive', 'production_lines', 'pqr_records'])
        || (isNotReadOnly() && name.matches('cpv_.*'));
    }

    // ── Profiles & Users ──
    match /profiles/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isQaRole());
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role == 'viewer'
        && request.resource.data.is_active == false
        && request.resource.data.access_status == 'pending';
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role', 'is_active', 'department', 'employee_id', 'access_status'
          ]))
        || isAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    match /users/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /roles/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /permissions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /user_permissions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Immutable audit trail ──
    match /audit_trail/{logId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser() && isNotReadOnly();
      allow update, delete: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser() && isNotReadOnly();
      allow update, delete: if false;
    }

    match /audit_events/{eventId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser() && isNotReadOnly();
      allow update, delete: if false;
    }

    match /audit_exports/{exportId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly();
      allow update, delete: if false;
    }

    match /esign_records/{recordId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser();
      allow update, delete: if false;
    }

    match /electronic_signatures/{recordId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser() && isNotReadOnly();
      allow update: if isActiveUser() && isQaRole()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'verified_at', 'verified_by']);
      allow delete: if false;
    }

    match /signature_meanings/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isNotReadOnly() && (isSuperAdmin() || isQaRole());
      allow delete: if isSuperAdmin();
    }

    match /signature_sessions/{docId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser() && isNotReadOnly();
      allow update: if isActiveUser() && isNotReadOnly();
      allow delete: if false;
    }

    match /signature_settings/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isNotReadOnly() && (isSuperAdmin() || isAdmin() || isQaRole());
      allow delete: if isSuperAdmin();
    }

    match /cpv_audit_trail/{logId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly();
      allow update, delete: if false;
    }

    match /packaging_audit_trail/{logId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly();
      allow update, delete: if false;
    }

    match /audit_logs_material/{logId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly();
      allow update, delete: if false;
    }

    // ── Notifications ──
    match /notifications/{docId} {
      allow read: if isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || resource.data.recipientRole == getProfileRole()
          || isAdmin()
        );
      allow create: if isActiveUser() && isNotReadOnly();
      allow update: if isActiveUser()
        && (
          resource.data.userId == request.auth.uid
          || resource.data.recipientRole == getProfileRole()
          || isAdmin()
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isRead', 'readStatus', 'readAt'
        ]);
      allow delete: if isSuperAdmin();
    }

    // ── Admin / master data ──
    match /system_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /esign_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /backup_history/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isSuperAdmin();
    }

    match /departments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isQaRole();
    }

    match /designations/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isQaRole();
    }

    match /company_sites/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /products/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isQaRole();
    }

    match /batches/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isNotReadOnly();
      allow delete: if isSuperAdmin();
    }

    // ── CPV (cpv_* prefix) ──
    match /cpv_{cpvModule}/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isNotReadOnly();
      allow delete: if isSuperAdmin();
    }

    // ── Document Acknowledgements (employees may update own records) ──
    match /document_acknowledgements/{docId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly() && canWriteCollection('document_acknowledgements');
      allow update: if isAuthenticated() && isNotReadOnly() && (
        canWriteCollection('document_acknowledgements')
        || resource.data.employee_id == request.auth.uid
      );
      allow delete: if isSuperAdmin();
    }

    match /read_confirmations/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotReadOnly();
      allow update, delete: if false;
    }

    match /document_reviews/{docId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly() && canWriteCollection('document_reviews');
      allow update: if isAuthenticated() && isNotReadOnly() && (
        canWriteCollection('document_reviews')
        || resource.data.reviewer_id == request.auth.uid
      );
      allow delete: if isSuperAdmin();
    }

    match /review_comments/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotReadOnly();
      allow update, delete: if isSuperAdmin();
    }

    match /document_approvals/{docId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly() && canWriteCollection('document_approvals');
      allow update: if isAuthenticated() && isNotReadOnly() && (
        canWriteCollection('document_approvals')
        || resource.data.approver_id == request.auth.uid
        || resource.data.delegated_to == request.auth.uid
      );
      allow delete: if isSuperAdmin();
    }

    match /approval_comments/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isNotReadOnly();
      allow update, delete: if isSuperAdmin();
    }

    match /approval_delegations/{docId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly() && canWriteCollection('approval_delegations');
      allow update, delete: if isSuperAdmin();
    }

    // ── Default: registered collections ──
    match /{collection}/{docId} {
      allow read: if isActiveUser()
        && (collection != 'lms_connections' || isTrainingCoordinator());
      allow create, update: if isActiveUser() && isNotReadOnly()
        && isRegisteredCollection(collection)
        && canWriteCollection(collection)
        && !isAuditCollection(collection);
      allow delete: if isSuperAdmin()
        && isRegisteredCollection(collection)
        && !isAuditCollection(collection);
    }
  }
}
