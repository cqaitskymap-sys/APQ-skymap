rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getProfileRole() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getProfileRole() == 'super_admin';
    }

    function isAdmin() {
      return isAuthenticated() && getProfileRole() in ['super_admin', 'admin'];
    }

    function isReadOnly() {
      return isAuthenticated() && getProfileRole() in ['auditor', 'viewer'];
    }

    function isNotReadOnly() {
      return isAuthenticated() && !isReadOnly();
    }

    function isQaRole() {
      return getProfileRole() in [
        'super_admin', 'admin', 'head_qa', 'qa_manager', 'qa_executive', 'qa'
      ];
    }

    function isQcRole() {
      return getProfileRole() in ['super_admin', 'admin', 'qc_manager', 'qc_executive', 'qc'];
    }

    function isProductionRole() {
      return getProfileRole() in ['super_admin', 'admin', 'production_manager', 'production_executive', 'production'];
    }

    function isEngineeringRole() {
      return getProfileRole() in ['super_admin', 'admin', 'engineering_manager', 'engineering_executive', 'engineering'];
    }

    function isWarehouseRole() {
      return getProfileRole() in ['super_admin', 'admin', 'warehouse_manager', 'warehouse_executive', 'warehouse'];
    }

    function isRegulatoryRole() {
      return getProfileRole() in ['super_admin', 'admin', 'regulatory_affairs', 'regulatory'];
    }

    function isAuditCollection(name) {
      return name.matches('.*audit_trail.*')
        || name.matches('.*audit_logs.*')
        || name in ['cpv_audit_trail', 'audit_logs', 'audit_trail', 'packaging_audit_trail', 'audit_logs_material'];
    }

    function isRegisteredCollection(name) {
      return name.matches('cpv_.*')
        || name in [
          'users', 'roles', 'permissions', 'products', 'batches',
          'cpv_reviews', 'cpp_parameters', 'cpp_results',
          'cqa_parameters', 'cqa_results', 'risk_assessment',
          'pqr_records', 'pqr_documents', 'pqr_batches',
          'deviations', 'oos_records', 'oos', 'capa_records', 'capa',
          'change_controls', 'change_control', 'stability_studies', 'stability',
          'complaints', 'recalls', 'recall_records', 'documents', 'dms_documents',
          'training_records', 'audits', 'audit_mgmt_records',
          'vendors', 'vendor_master', 'vendor_records',
          'validation_records', 'csv_systems',
          'equipment_master', 'equipment_records', 'calibration_records',
          'monitoring_records', 'warehouse_materials', 'warehouse_records',
          'ebmr_records', 'notifications',
          'material_master', 'packaging_material_master',
          'departments', 'designations', 'company_sites', 'parameters',
          'workflows', 'approval_matrix', 'document_numbering',
          'notification_settings', 'esign_settings', 'system_settings', 'backup_history'
        ];
    }

    function canWriteCollection(name) {
      return isSuperAdmin()
        || (isAdmin() && name in ['users', 'roles', 'permissions', 'products', 'batches', 'departments', 'designations'])
        || (isQaRole() && name in ['pqr_records', 'pqr_documents', 'deviations', 'capa_records', 'capa', 'change_controls', 'change_control', 'complaints', 'recalls', 'recall_records', 'stability_studies', 'training_records', 'documents', 'dms_documents'])
        || (isQcRole() && name in ['oos_records', 'oos', 'cqa_parameters', 'cqa_results', 'stability_studies', 'stability'])
        || (isProductionRole() && name in ['batches', 'cpp_parameters', 'cpp_results', 'ebmr_records'])
        || (isEngineeringRole() && name in ['equipment_master', 'equipment_records', 'calibration_records', 'validation_records', 'csv_systems', 'monitoring_records'])
        || (isWarehouseRole() && name in ['warehouse_materials', 'warehouse_records', 'material_master'])
        || (isRegulatoryRole() && name in ['change_controls', 'change_control', 'recalls', 'recall_records', 'documents', 'dms_documents', 'pqr_records'])
        || (isNotReadOnly() && name.matches('cpv_.*'));
    }

    // ── Profiles & Users ──
    match /profiles/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isQaRole());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isSuperAdmin();
    }

    match /users/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /roles/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /permissions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── Immutable audit trail ──
    match /audit_trail/{logId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly();
      allow update, delete: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly();
      allow update, delete: if false;
    }

    match /cpv_audit_trail/{logId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly();
      allow update, delete: if false;
    }

    match /packaging_audit_trail/{logId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly();
      allow update, delete: if false;
    }

    match /audit_logs_material/{logId} {
      allow read: if isAuthenticated();
      allow create: if isNotReadOnly();
      allow update, delete: if false;
    }

    // ── Notifications ──
    match /notifications/{docId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isNotReadOnly();
      allow update: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSuperAdmin();
    }

    // ── Admin / master data ──
    match /system_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /esign_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /backup_history/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isSuperAdmin();
    }

    match /departments/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isQaRole();
    }

    match /designations/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isQaRole();
    }

    match /company_sites/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /products/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isQaRole();
    }

    match /batches/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isNotReadOnly();
      allow delete: if isSuperAdmin();
    }

    // ── CPV (cpv_* prefix) ──
    match /cpv_{cpvModule}/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isNotReadOnly();
      allow delete: if isSuperAdmin();
    }

    // ── Default: registered collections ──
    match /{collection}/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isNotReadOnly()
        && isRegisteredCollection(collection)
        && canWriteCollection(collection)
        && !isAuditCollection(collection);
      allow delete: if isSuperAdmin()
        && isRegisteredCollection(collection)
        && !isAuditCollection(collection);
    }
  }
}
