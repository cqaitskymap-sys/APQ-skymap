# Firebase — copy to .env.local (local) OR add in Netlify Dashboard (production)
# Do NOT commit .env.local to version control

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Netlify deployment ──
# 1. Go to Netlify → Your site → Site configuration → Environment variables
# 2. Add ALL six NEXT_PUBLIC_FIREBASE_* variables above (from Firebase Console)
# 3. Trigger a new deploy (Deploys → Trigger deploy → Deploy site)
# IMPORTANT: NEXT_PUBLIC_* vars are baked in at BUILD time — redeploy after adding them.

# Optional: Firebase Analytics
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Force demo auth (local testing without Firebase)
NEXT_PUBLIC_DEMO_AUTH=false

# Firebase Emulator Suite: npm run emulators
# NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
